#!/usr/bin/env bash
set -euo pipefail

state_dir="${XDG_RUNTIME_DIR:-$HOME/.cache/keystrel}"
mkdir -p "$state_dir"
lock_file="$state_dir/keystrel-ptt.lock"
stamp_file="$state_dir/keystrel-ptt.last"
cancel_file="$state_dir/keystrel-ptt.cancel"
repeat_file="$state_dir/keystrel-ptt.repeat"

debounce_ms="${KEYSTREL_PTT_DEBOUNCE_MS:-${STT_PTT_DEBOUNCE_MS:-180}}"
ptt_double_press_cancel="${KEYSTREL_PTT_DOUBLE_PRESS_CANCEL:-${STT_PTT_DOUBLE_PRESS_CANCEL:-1}}"
ptt_cancel_debounce_ms="${KEYSTREL_PTT_CANCEL_DEBOUNCE_MS:-${STT_PTT_CANCEL_DEBOUNCE_MS:-150}}"
keystrel_client_bin="${KEYSTREL_CLIENT_BIN:-${STT_CLIENT_BIN:-$HOME/.local/bin/keystrel-client}}"
type_delay_ms="${KEYSTREL_TYPE_DELAY_MS:-${STT_TYPE_DELAY_MS:-1}}"

ptt_chime_enabled="${KEYSTREL_PTT_CHIME_ENABLED:-${STT_PTT_CHIME_ENABLED:-1}}"
ptt_chime_backend="${KEYSTREL_PTT_CHIME_BACKEND:-${STT_PTT_CHIME_BACKEND:-pipewire}}"

default_chime_file="$HOME/.local/share/keystrel/chime_personality.wav"
if [[ ! -f "$default_chime_file" && -f "$HOME/.local/share/stt/chime_personality.wav" ]]; then
  default_chime_file="$HOME/.local/share/stt/chime_personality.wav"
fi
ptt_chime_file="${KEYSTREL_PTT_CHIME_FILE:-${STT_PTT_CHIME_FILE:-$default_chime_file}}"

ptt_chime_target="${KEYSTREL_PTT_CHIME_TARGET:-${STT_PTT_CHIME_TARGET:-}}"
ptt_chime_role="${KEYSTREL_PTT_CHIME_ROLE:-${STT_PTT_CHIME_ROLE:-Music}}"
ptt_chime_volume="${KEYSTREL_PTT_CHIME_VOLUME:-${STT_PTT_CHIME_VOLUME:-1.0}}"
ptt_chime_cooldown_ms="${KEYSTREL_PTT_CHIME_COOLDOWN_MS:-${STT_PTT_CHIME_COOLDOWN_MS:-0}}"
ptt_mute_start_delay_ms="${KEYSTREL_PTT_MUTE_START_DELAY_MS:-${STT_PTT_MUTE_START_DELAY_MS:-}}"
ptt_debug_log="${KEYSTREL_PTT_DEBUG_LOG:-${STT_PTT_DEBUG_LOG:-}}"
ptt_repeat_delay_ms="${KEYSTREL_PTT_REPEAT_DELAY_MS:-${STT_PTT_REPEAT_DELAY_MS:-}}"
ptt_repeat_interval_ms="${KEYSTREL_PTT_REPEAT_INTERVAL_MS:-${STT_PTT_REPEAT_INTERVAL_MS:-}}"
ptt_repeat_window_ms=""
ptt_repeat_chain_ms=""

log_debug() {
  [[ -n "$ptt_debug_log" ]] || return 0
  printf '%s %s\n' "$(date +'%Y-%m-%dT%H:%M:%S%z')" "$*" >>"$ptt_debug_log" 2>/dev/null || true
}

read_gsettings_uint() {
  local schema="$1"
  local key="$2"
  local raw

  command -v gsettings >/dev/null 2>&1 || return 1
  raw="$(gsettings get "$schema" "$key" 2>/dev/null || true)"
  [[ "$raw" =~ ([0-9]+) ]] || return 1
  printf '%s' "${BASH_REMATCH[1]}"
}

normalize_settings() {
  if ! [[ "$debounce_ms" =~ ^[0-9]+$ ]]; then
    debounce_ms=180
  fi

  if ! [[ "$ptt_double_press_cancel" =~ ^(0|1)$ ]]; then
    ptt_double_press_cancel=1
  fi

  if ! [[ "$ptt_cancel_debounce_ms" =~ ^[0-9]+$ ]]; then
    ptt_cancel_debounce_ms=150
  fi

  if ! [[ "$type_delay_ms" =~ ^[0-9]+$ ]]; then
    type_delay_ms=1
  fi

  if ! [[ "$ptt_chime_enabled" =~ ^(0|1)$ ]]; then
    ptt_chime_enabled=1
  fi

  if ! [[ "$ptt_chime_cooldown_ms" =~ ^[0-9]+$ ]]; then
    ptt_chime_cooldown_ms=0
  fi

  if [[ -n "$ptt_mute_start_delay_ms" ]] && ! [[ "$ptt_mute_start_delay_ms" =~ ^[0-9]+$ ]]; then
    ptt_mute_start_delay_ms=""
  fi

  if [[ -z "$ptt_chime_target" ]] && command -v pactl >/dev/null 2>&1; then
    default_sink="$(pactl info 2>/dev/null | sed -n 's/^Default Sink: //p')"
    if [[ -n "$default_sink" ]]; then
      ptt_chime_target="$default_sink"
    fi
  fi

  if [[ -z "$ptt_mute_start_delay_ms" ]]; then
    ptt_mute_start_delay_ms=0
  fi

  if [[ -z "$ptt_repeat_delay_ms" ]]; then
    ptt_repeat_delay_ms="$(read_gsettings_uint org.gnome.desktop.peripherals.keyboard delay || true)"
  fi
  if [[ -z "$ptt_repeat_interval_ms" ]]; then
    ptt_repeat_interval_ms="$(read_gsettings_uint org.gnome.desktop.peripherals.keyboard repeat-interval || true)"
  fi

  if ! [[ "$ptt_repeat_delay_ms" =~ ^[0-9]+$ ]]; then
    ptt_repeat_delay_ms=500
  fi
  if ! [[ "$ptt_repeat_interval_ms" =~ ^[0-9]+$ ]]; then
    ptt_repeat_interval_ms=30
  fi
  if (( ptt_repeat_interval_ms <= 0 )); then
    ptt_repeat_interval_ms=30
  fi

  ptt_repeat_window_ms=$((ptt_repeat_interval_ms / 2))
  if (( ptt_repeat_window_ms < 12 )); then
    ptt_repeat_window_ms=12
  fi
  if (( ptt_repeat_window_ms > 30 )); then
    ptt_repeat_window_ms=30
  fi

  ptt_repeat_chain_ms=$((ptt_repeat_interval_ms + ptt_repeat_window_ms))
  if (( ptt_repeat_chain_ms < 25 )); then
    ptt_repeat_chain_ms=25
  fi
}

require_prerequisites() {
  if ! command -v flock >/dev/null 2>&1; then
    printf '[keystrel-ptt] missing flock; install util-linux\n' >&2
    exit 5
  fi

  if [[ "${XDG_SESSION_TYPE:-}" != "x11" ]]; then
    printf '[keystrel-ptt] this command currently requires an X11 session\n' >&2
    exit 2
  fi

  if [[ ! -x "$keystrel_client_bin" ]]; then
    printf '[keystrel-ptt] missing executable keystrel-client at %s\n' "$keystrel_client_bin" >&2
    exit 3
  fi

  if ! command -v xdotool >/dev/null 2>&1; then
    printf '[keystrel-ptt] missing xdotool; install package xdotool\n' >&2
    exit 4
  fi
}

run_chime_pipewire() {
  command -v pw-play >/dev/null 2>&1 || return 1
  [[ -f "$ptt_chime_file" ]] || return 1

  if [[ -n "$ptt_chime_target" ]]; then
    pw-play --target "$ptt_chime_target" --media-role "$ptt_chime_role" --volume "$ptt_chime_volume" --latency 20ms "$ptt_chime_file" >/dev/null 2>&1
  else
    pw-play --media-role "$ptt_chime_role" --volume "$ptt_chime_volume" --latency 20ms "$ptt_chime_file" >/dev/null 2>&1
  fi
}

run_chime_paplay() {
  command -v paplay >/dev/null 2>&1 || return 1
  [[ -f "$ptt_chime_file" ]] || return 1
  paplay "$ptt_chime_file" >/dev/null 2>&1
}

run_chime_canberra() {
  command -v canberra-gtk-play >/dev/null 2>&1 || return 1
  if [[ -f "$ptt_chime_file" ]]; then
    canberra-gtk-play -d "keystrel ptt" -f "$ptt_chime_file" >/dev/null 2>&1
  else
    canberra-gtk-play -d "keystrel ptt" -i bell >/dev/null 2>&1
  fi
}

play_ptt_chime() {
  [[ "$ptt_chime_enabled" == "1" ]] || return 0

  played=0

  case "$ptt_chime_backend" in
    auto)
      if run_chime_pipewire; then
        played=1
        log_debug "chime ok backend=pipewire target=${ptt_chime_target:-auto}"
      elif run_chime_paplay; then
        played=1
        log_debug "chime ok backend=paplay"
      elif run_chime_canberra; then
        played=1
        log_debug "chime ok backend=canberra"
      fi
      ;;
    pipewire)
      if run_chime_pipewire; then
        played=1
        log_debug "chime ok backend=pipewire target=${ptt_chime_target:-auto}"
      elif run_chime_paplay; then
        played=1
        log_debug "chime fallback backend=paplay"
      elif run_chime_canberra; then
        played=1
        log_debug "chime fallback backend=canberra"
      fi
      ;;
    paplay)
      if run_chime_paplay; then
        played=1
        log_debug "chime ok backend=paplay"
      elif run_chime_pipewire; then
        played=1
        log_debug "chime fallback backend=pipewire target=${ptt_chime_target:-auto}"
      elif run_chime_canberra; then
        played=1
        log_debug "chime fallback backend=canberra"
      fi
      ;;
    canberra)
      if run_chime_canberra; then
        played=1
        log_debug "chime ok backend=canberra"
      elif run_chime_pipewire; then
        played=1
        log_debug "chime fallback backend=pipewire target=${ptt_chime_target:-auto}"
      elif run_chime_paplay; then
        played=1
        log_debug "chime fallback backend=paplay"
      fi
      ;;
    none)
      ;;
    *)
      if run_chime_pipewire; then
        played=1
        log_debug "chime ok backend=pipewire target=${ptt_chime_target:-auto}"
      elif run_chime_paplay; then
        played=1
        log_debug "chime fallback backend=paplay"
      elif run_chime_canberra; then
        played=1
        log_debug "chime fallback backend=canberra"
      fi
      ;;
  esac

  if [[ "$played" != "1" ]]; then
    log_debug "chime failed backend=${ptt_chime_backend} file=${ptt_chime_file} target=${ptt_chime_target}"
  fi

  if (( ptt_chime_cooldown_ms > 0 )); then
    chime_wait_s=$((ptt_chime_cooldown_ms / 1000))
    chime_wait_ms=$((ptt_chime_cooldown_ms % 1000))
    sleep "${chime_wait_s}.$(printf '%03d' "$chime_wait_ms")"
  fi
}

cleanup_cancel_file() {
  rm -f "$cancel_file" >/dev/null 2>&1 || true
}

cleanup_repeat_file() {
  rm -f "$repeat_file" >/dev/null 2>&1 || true
}

is_probable_key_repeat_press() {
  local now_ms="$1"
  local running_ms="$2"
  local elapsed_ms
  local repeat_window_ms
  local repeat_lower_ms
  local repeat_upper_ms
  local last_repeat_ms=""

  [[ "$running_ms" =~ ^[0-9]+$ ]] || return 1
  elapsed_ms=$((now_ms - running_ms))
  if (( elapsed_ms < 0 )); then
    return 1
  fi

  repeat_window_ms="$ptt_repeat_window_ms"

  if [[ -f "$repeat_file" ]]; then
    last_repeat_ms="$(<"$repeat_file")"
  fi
  if [[ "$last_repeat_ms" =~ ^[0-9]+$ ]] && (( now_ms - last_repeat_ms <= ptt_repeat_chain_ms )); then
    printf '%s' "$now_ms" >"$repeat_file"
    return 0
  fi

  repeat_lower_ms=$((ptt_repeat_delay_ms - repeat_window_ms))
  if (( repeat_lower_ms < 0 )); then
    repeat_lower_ms=0
  fi
  repeat_upper_ms=$((ptt_repeat_delay_ms + repeat_window_ms))

  if (( elapsed_ms >= repeat_lower_ms && elapsed_ms <= repeat_upper_ms )); then
    printf '%s' "$now_ms" >"$repeat_file"
    return 0
  fi

  return 1
}

handle_running_capture_press() {
  if [[ "$ptt_double_press_cancel" != "1" ]]; then
    exit 0
  fi

  now_ms="$(date +%s%3N)"
  running_ms="0"
  if [[ -f "$stamp_file" ]]; then
    running_ms="$(<"$stamp_file")"
  fi

  if [[ "$running_ms" =~ ^[0-9]+$ ]] && (( now_ms - running_ms < ptt_cancel_debounce_ms )); then
    log_debug "cancel ignored elapsed_ms=$((now_ms - running_ms)) cancel_debounce_ms=${ptt_cancel_debounce_ms}"
    exit 0
  fi

  if is_probable_key_repeat_press "$now_ms" "$running_ms"; then
    log_debug "cancel ignored probable key-repeat elapsed_ms=$((now_ms - running_ms)) repeat_delay_ms=${ptt_repeat_delay_ms} repeat_interval_ms=${ptt_repeat_interval_ms} repeat_window_ms=${ptt_repeat_window_ms}"
    exit 0
  fi

  printf '%s' "$now_ms" >"$cancel_file"
  printf '%s' "$now_ms" >"$stamp_file"
  cleanup_repeat_file
  log_debug "cancel requested"
  exit 0
}

is_debounced_launch() {
  local now_ms="$1"
  if [[ -f "$stamp_file" ]]; then
    local last_ms
    last_ms="$(<"$stamp_file")"
    if [[ "$last_ms" =~ ^[0-9]+$ ]] && (( now_ms - last_ms < debounce_ms )); then
      return 0
    fi
  fi
  return 1
}

capture_text() {
  KEYSTREL_START_CHIME=0 \
    KEYSTREL_MUTE_START_DELAY_MS="$ptt_mute_start_delay_ms" \
    KEYSTREL_CANCEL_FILE="$cancel_file" \
    "$keystrel_client_bin" "$@"
}

main() {
  normalize_settings
  require_prerequisites

  exec 9>"$lock_file"
  if ! flock -n 9; then
    handle_running_capture_press
  fi

  now_ms="$(date +%s%3N)"
  if is_debounced_launch "$now_ms"; then
    exit 0
  fi

  printf '%s' "$now_ms" >"$stamp_file"
  cleanup_cancel_file
  cleanup_repeat_file

  play_ptt_chime

  log_debug "capture start mute_delay_ms=${ptt_mute_start_delay_ms}"
  text="$(capture_text "$@")"
  text="${text//$'\r'/}"
  text="${text//$'\n'/ }"

  if [[ -f "$cancel_file" ]]; then
    log_debug "typing skipped due cancel request"
    cleanup_cancel_file
    exit 0
  fi

  if [[ -z "${text//[[:space:]]/}" ]]; then
    cleanup_cancel_file
    exit 0
  fi

  xdotool type --clearmodifiers --delay "$type_delay_ms" -- "$text"

  if [[ "${KEYSTREL_PTT_SEND_ENTER:-${STT_PTT_SEND_ENTER:-0}}" == "1" ]]; then
    xdotool key --clearmodifiers Return
  fi

  cleanup_cancel_file
  cleanup_repeat_file
}

main "$@"
