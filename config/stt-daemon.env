STT_MODEL=large-v3
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16
STT_BEAM_SIZE=5
STT_BEST_OF=5
STT_VAD_FILTER=1
STT_LANGUAGE=en
STT_SOCKET=~/.cache/stt/faster-whisper.sock
# Set STT_TCP_LISTEN to the server node's Tailscale IPv4 (tailscale ip -4).
# Leave empty to disable remote TCP transport.
STT_TCP_LISTEN=
STT_TCP_PORT=8765
STT_SERVER_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
STT_MAX_REQUEST_BYTES=10485760
STT_MAX_AUDIO_BYTES=6291456
