# Copy to .env, ~/.config/keystrel-client.env, or export in shell profile.
# This enables remote GPU inference over Tailscale while keeping local
# mic/chime/PTT behavior on the client machine.

# Remote daemon endpoint on the GPU server node.
KEYSTREL_SERVER=tcp://<tailscale-ip>:8765

# Must match KEYSTREL_SERVER_TOKEN configured on the server.
KEYSTREL_SERVER_TOKEN=REPLACE_WITH_SAME_SECRET_AS_SERVER

# Remote transport timeout for connect/read.
KEYSTREL_SERVER_TIMEOUT=30

# Optional: delay output muting so start chime is audible on Bluetooth.
KEYSTREL_MUTE_START_DELAY_MS=1200

# Optional: disable local start chime if you only want PTT chime.
# KEYSTREL_START_CHIME=0

# Optional decode overrides.
# KEYSTREL_LANGUAGE=en
# KEYSTREL_BEAM_SIZE=5
# KEYSTREL_BEST_OF=5
